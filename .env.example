# Admin API listen port
PORT=8090

# Path to region / media-server registry (copy from servers.json.example)
# SERVERS_CONFIG=servers.json

# Device registry persistence file
DEVICES_FILE=data/devices.json

# Fallback when servers.json is absent:
MEDIA_SERVER_URL=http://127.0.0.1:8081
MEDIA_PUBLIC_HOST=127.0.0.1
